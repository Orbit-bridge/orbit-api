# orbit-api — Environment Variables
# Copy this file to .env and fill in values before starting.
# Never commit .env to version control.

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────

PORT=3000
LOG_LEVEL=info           # trace | debug | info | warn | error
NODE_ENV=development     # development | production

# ─────────────────────────────────────────────────────────────
# MCP server mode
# Set to "stdio" to start as an MCP server instead of HTTP.
# Leave unset or set to any other value for normal HTTP mode.
# ─────────────────────────────────────────────────────────────

# MCP_MODE=stdio

# ─────────────────────────────────────────────────────────────
# Stellar
# ─────────────────────────────────────────────────────────────

STELLAR_NETWORK=testnet                                    # mainnet | testnet
STELLAR_HORIZON_URL=https://horizon.stellar.org            # mainnet Horizon
# STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org  # testnet Horizon

# ─────────────────────────────────────────────────────────────
# EVM RPC URLs
# At least one is required for route pricing.
# ─────────────────────────────────────────────────────────────

EVM_RPC_ETHEREUM=https://eth.llamarpc.com
EVM_RPC_BASE=https://mainnet.base.org
EVM_RPC_ARBITRUM=https://arb1.arbitrum.io/rpc
EVM_RPC_OPTIMISM=https://mainnet.optimism.io
EVM_RPC_POLYGON=https://polygon-rpc.com
EVM_RPC_AVALANCHE=https://api.avax.network/ext/bc/C/rpc
EVM_RPC_BSC=https://bsc-dataseed.binance.org

# ─────────────────────────────────────────────────────────────
# Price Oracle (Pyth)
# ─────────────────────────────────────────────────────────────

PYTH_HERMES_URL=https://hermes.pyth.network

# ─────────────────────────────────────────────────────────────
# Redis (optional — required for quote caching + rate limiting)
# If not set, quotes are cached in memory (no TTL guarantee across restarts).
# ─────────────────────────────────────────────────────────────

# REDIS_URL=redis://localhost:6379
# REDIS_URL=redis://:password@redis:6379   # Docker Compose

# ─────────────────────────────────────────────────────────────
# Authentication
# API keys for POST /execute (ECDSA verification) and
# developer API key access. Generate with: npm run generate-key
# ─────────────────────────────────────────────────────────────

# API_KEYS=key_abc123,key_def456   # comma-separated list of valid API keys

# ─────────────────────────────────────────────────────────────
# Database (SQLite via Drizzle)
# ─────────────────────────────────────────────────────────────

DB_PATH=./orbit.db

# ─────────────────────────────────────────────────────────────
# Rate limiting
# ─────────────────────────────────────────────────────────────

RATE_LIMIT_WINDOW_MS=60000     # 1 minute
RATE_LIMIT_MAX_REQUESTS=60     # per window per IP

# ─────────────────────────────────────────────────────────────
# CORS
# Comma-separated list of allowed origins. * allows all (dev only).
# ─────────────────────────────────────────────────────────────

CORS_ORIGINS=*
# CORS_ORIGINS=https://app.orbitbridge.xyz,https://staging.orbitbridge.xyz

# ─────────────────────────────────────────────────────────────
# Webhooks (optional)
# POST request sent on execution status change events.
# ─────────────────────────────────────────────────────────────

# WEBHOOK_URL=https://your-server.example.com/orbit-webhook
# WEBHOOK_SECRET=your-hmac-signing-secret

# ─────────────────────────────────────────────────────────────
# Bridge-specific (optional overrides)
# ─────────────────────────────────────────────────────────────

# WORMHOLE_GUARDIAN_RPC=https://wormhole-v2-mainnet-api.certus.one
# CCTP_IRIS_URL=https://iris-api.circle.com

# ─────────────────────────────────────────────────────────────
# Development / testing only
# ─────────────────────────────────────────────────────────────

# TESTNET_ENABLED=true           # allow testnet operations
# DISABLE_SIMULATION=false       # skip eth_call simulation before submit (never in prod)
