{
  "name": "@orbit-bridge/api",
  "version": "0.1.0",
  "description": "Public API, MCP server, and orchestration layer for Orbit",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist"
  },
  "keywords": ["cross-chain", "bridge", "stellar", "api", "mcp", "ai-agent"],
  "license": "MIT",
  "dependencies": {
