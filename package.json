    "@modelcontextprotocol/sdk": "^1.0.0",
    "@orbit-bridge/core": "*",
    "@orbit-bridge/executor": "*",
    "zod": "^3.23.0",
    "zod-validator": "^0.4.0",
    "@hono/zod-validator": "^0.4.0",
    "uuid": "^10.0.0",
    "dotenv": "^16.4.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.19.0",
    "vitest": "^2.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0"
  }
}
